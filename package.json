{
  "name": "@elvatis_com/clawhub-scanner",
  "version": "0.1.1",
  "description": "Scan ClawHub skills for malware, credential theft, and security risks",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawhub-scanner": "dist/index.js"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "clawhub",
    "security",
    "scanner",
    "malware"
  ],
  "author": "Elvatis <info@elvatis.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/elvatis/clawhub-scanner"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
